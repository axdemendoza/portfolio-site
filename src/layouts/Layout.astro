---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Axel De Mendoza portfolio and blog" } = Astro.props;
---

<html lang="en" class="bg-neutral-950 text-neutral-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100 antialiased">
    <header class="border-b border-neutral-800">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
        <a href="/" class="text-lg font-semibold tracking-tight">Axel De Mendoza</a>

        <nav class="flex items-center gap-6 text-sm text-neutral-300">
          <a href="/blog" class="transition hover:text-white">Blog</a>
          <a
            href="https://github.com/axdemendoza"
            target="_blank"
            rel="noreferrer"
            class="transition hover:text-white"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>