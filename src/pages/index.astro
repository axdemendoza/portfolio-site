---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Axel De Mendoza"
  description="Portfolio, engineering projects, and technical writing by Axel De Mendoza."
>
  <section class="max-w-3xl">
    <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-400">
      Senior Data Scientist · ML Systems · HPC
    </p>

    <h1 class="mb-6 text-5xl font-semibold tracking-tight text-white">
      I build production ML, data, and software systems.
    </h1>

    <p class="mb-8 text-lg leading-8 text-neutral-300">
      This site is where I share technical projects, engineering writeups, and lessons from building
      real systems in production.
    </p>

    <div class="flex gap-4">
      <a
        href="/blog"
        class="rounded-lg bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:opacity-90"
      >
        Read the blog
      </a>

      <a
        href="https://github.com/axdemendoza"
        target="_blank"
        rel="noreferrer"
        class="rounded-lg border border-neutral-700 px-5 py-3 text-sm font-medium text-neutral-100 transition hover:border-neutral-500"
      >
        View GitHub
      </a>
    </div>
  </section>
</Layout>